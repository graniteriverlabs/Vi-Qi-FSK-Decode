#else
static int sentindex;
void polling_data_decode(uint8_t *aRxBuffer)
{
	extern uint8_t Arr[MAX_LINES][MAX_LINE_LEN];
	extern volatile uint16_t lineIndex;
	uint16_t l = API_LENGTH_DECODE(aRxBuffer);

	if (aRxBuffer == NULL)
	    {
	        printf("POLLING ERR: NULL buffer\n");
	        return;
	    }

	if (sentindex >= MAX_LINES)
	{
		printf("POLLING WARN: sentindex wrap\n");
        aRxBuffer[l++] = POLL_STATUS_ERROR;
        API_LENGTH_ENCODE(aRxBuffer, l);
        tcp_send_response(aRxBuffer, l, (2 * NX_IP_PERIODIC_RATE));
        sentindex = 0;
		return;
	}

	if (sentindex == lineIndex)
	{
		printf("POLLING INFO: no UART data\n");
        aRxBuffer[l++] = POLL_STATUS_NO_DATA;
        API_LENGTH_ENCODE(aRxBuffer, l);
        tcp_send_response(aRxBuffer, l, (2 * NX_IP_PERIODIC_RATE));
		return;
	}

    if ((l + MAX_LINE_LEN) > MAX_API_BUFFER_LEN)
    {
        printf("POLLING ERR: API buffer overflow\n");
        aRxBuffer[l++] = POLL_STATUS_ERROR;
        API_LENGTH_ENCODE(aRxBuffer, l);
        tcp_send_response(aRxBuffer, l, (2 * NX_IP_PERIODIC_RATE));
        return;
    }


	memcpy(&aRxBuffer[l], &Arr[sentindex++][0], MAX_LINE_LEN);
	l += MAX_LINE_LEN;

	API_LENGTH_ENCODE(aRxBuffer,l);
	tcp_send_response(aRxBuffer,l,(2 * NX_IP_PERIODIC_RATE));
}
#endif
void get_system_details_handler(uint8_t *aRxBuffer){
	uint8_t lParType = aRxBuffer[7];
//	uint8_t lsubParType = aRxBuffer[8];
	switch((sys_details_e)lParType){
		case SYS_FW_VERSION:
			fw_version_fetch(aRxBuffer);
		break;
		case POLLING_DATA:
			polling_data_decode(aRxBuffer);
			break;
	}
}
/**
 * @brief Get the cmd handler object for processing GET commands
 * 
 * @param aRxBuffer : incoming API buffer
 */
void get_cmd_handler(uint8_t *aRxBuffer){

	uint8_t lFuncType = aRxBuffer[5];
	switch((func_type_e)lFuncType){
		case POWER_MGMT:
			break;
		case QI_PKT_MSKG:
			break;
		case QI_PKT_CGF:
			break;
		case QI_PKT_CTRL:
				break;
		case QI_TIM_CFG:
			break;
		case QI_TSTR_MODE_CFG:
			break;
		case CALIB:
			break;
		case SYS_DETAILS:
			get_system_details_handler(aRxBuffer);
		break;

		case MISC:
		
		break;
	}
}

void set_cmd_handler(uint8_t *aRxBuffer){
	uint8_t lFuncType = aRxBuffer[5];
	switch((func_type_e)lFuncType){
	case POWER_MGMT:
		break;
	case QI_PKT_MSKG:
		break;
	case QI_PKT_CGF:
		break;
	case QI_PKT_CTRL:
			break;
	case QI_TIM_CFG:
		break;
	case QI_TSTR_MODE_CFG:
		break;
	case CALIB:
		break;
	case SYS_DETAILS:
		break;
	case MISC:
		break;
	default:
		break;
	}
	//echoback for set commands
    tcp_send_response(aRxBuffer, API_LENGTH_DECODE(aRxBuffer), (2 * NX_IP_PERIODIC_RATE));

}
/**
 * @brief Process the incoming application command, 
 * Entry point for API command processing that differentiates SET/GET/PGM commands
 * 
 * @param aRxBuffer 
 */
void process_app_cmd(uint8_t *aRxBuffer){

	uint8_t lCmdType = aRxBuffer[0];
	switch((cmd_type_e)lCmdType ){
		case SET_CMD:
			set_cmd_handler(aRxBuffer);
			break;
		case GET_CMD:
			get_cmd_handler(aRxBuffer);
			break;
		case PGM_CMD:
			break;
	}
}
void grl_app_init(){
	ipc_shm_init();
    __HAL_RCC_HSEM_CLK_ENABLE();
	cm4_reply_ready = 0;
	api_rx = 0;

	//	sentindex = 0;
    printf("M7_TO_M4 @ %p\n", &SHM_M7_TO_M4);
    printf("M4_TO_M7 @ %p\n", &SHM_M4_TO_M7);
}

/**
 * @brief API Process Thread Entry.
 * THis is used to process the incoming API commands from TCP/IP stack, This thread is waken up from mulitple events
 * - API RX Event - when new API command is received from TCP/IP stack
 * - CM4 Interrupt Event - when CM4 has sent a reply to CM7
 * 
 * @param thread_input 
 * @return VOID 
 */
VOID ApiProcess_Thread_Entry(ULONG thread_input)
{
    ULONG flags;
    uint8_t local_buf[TCP_CHUNK_SIZE];
    uint16_t len;
    uint32_t shm_len = 0;
    grl_app_init();
    grl_tim_init();
    while (1)
    {
        tx_event_flags_get(&ApiEventFlags, (API_RX_EVT | CM4_INTR), TX_OR_CLEAR, &flags, NX_WAIT_FOREVER);

        if (flags & API_RX_EVT)
//    	if(api_rx)
        {
    		api_rx = 0;
            if(api_dequeue(local_buf, &len) == 0)
            {
                process_app_cmd(local_buf);
            }
        }
        if(flags & CM4_INTR)
        {
        	if(cm4_reply_ready)
        	{
        		cm4_reply_ready = 0;

        		SCB_InvalidateDCache_by_Addr((uint32_t*)&SHM_M4_TO_M7,
        		                                     cache_align_size(sizeof(SHM_M4_TO_M7)));
        		__DMB();

        		shm_len = SHM_M4_TO_M7.len;
        		if (shm_len == 0 || shm_len > API_MAX_LEN) {
        		    printf("SHM len bad: %lu\n", shm_len);
        		    continue;
        		}
        		memcpy(ltx_buffer, (void*)SHM_M4_TO_M7.data, shm_len);
                tcp_send_response(ltx_buffer, (USHORT)shm_len, (2 * NX_IP_PERIODIC_RATE));
        	}
        }
    }
}
