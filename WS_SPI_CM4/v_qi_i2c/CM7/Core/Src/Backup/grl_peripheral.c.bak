/**I2C*/
extern I2C_HandleTypeDef hi2c4;
#define CPS_SLAVE_ADDR		(0x30<<1)
#define REG_V_RECT			0x0104

static int err_hits;

static inline uint16_t U16_LE(const uint8_t *p)
{
  return (uint16_t)(p[0] | ((uint16_t)p[1] << 8)); // change if BE
}
uint8_t g_i2c_busy;
void HAL_I2C_MemRxCpltCallback(I2C_HandleTypeDef *hi2c)
{
  if (hi2c->Instance == I2C4)
  {
	  g_i2c_busy = 0;
		grl_vi_sample_t s;
		s.ts_ms = HAL_GetTick();
		s.r_v     = U16_LE(&g_vi_raw[0]);   // 0x0104..05
		s.r_i     = U16_LE(&g_vi_raw[4]);   // 0x0108..09
		//		s.seq   = ++g_vi_seq;
		//		s.errs  = g_vi_errs;
		g_vi = s;
  }
}

void HAL_I2C_ErrorCallback(I2C_HandleTypeDef *hi2c)
{
  if (hi2c->Instance == I2C4)
  {
    err_hits++;
    g_i2c_busy = 0;
  }
}
void grl_rv_ri_i2c_read_init(uint8_t RB){

	 if (g_i2c_busy) return;

	  g_i2c_busy = 1;

	if (HAL_I2C_Mem_Read_DMA(&hi2c4,
								CPS_SLAVE_ADDR,
								REG_V_RECT,
								I2C_MEMADD_SIZE_16BIT,
								g_vi_raw,
								RB) != HAL_OK){
		err_hits++;
		volatile HAL_I2C_StateTypeDef s = HAL_I2C_GetState(&hi2c4);
		volatile uint32_t e = HAL_I2C_GetError(&hi2c4);
		(void)s; (void)e;
	}else{

	}
}


